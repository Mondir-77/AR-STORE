// Auto-resume session (guest or user)
(function initSession(){
  try{
    const s=JSON.parse(localStorage.getItem(SESSION_KEY)||"null");
    if(!s) return;
    document.getElementById("loginSection").style.display="none";
    document.getElementById("signInModal").style.display="none";
    document.getElementById("createModal").style.display="none";
    if(s.mode==="guest"){
      document.getElementById("username").innerText="Guest";
      document.getElementById("userAvatar").src="gust.png";
      showStore();
      return;
    }
    document.getElementById("username").innerText=userProfile.username||"Guest";
    document.getElementById("userAvatar").src=userProfile.avatar||"gust.png";

    if(isFirebaseReady()){
      auth.onAuthStateChanged((u)=>{
        if(u){
          applyAuthedUI(u);
        }
      });
    }
    showStore();
  }catch(e){}
})();
