/* ========== SIGN IN - Validate then enter store ========== */
async function doSignIn(){
  const email=document.getElementById("emailInput").value.trim().toLowerCase();
  const pass=document.getElementById("passInput").value;
  if(!email||!pass){
    const msg=currentLang==="ar"?"يرجى إدخال البريد وكلمة المرور":currentLang==="fr"?"Veuillez entrer l'email et le mot de passe":"Please enter email and password";
    alert(msg);
    return;
  }

  // Firebase mode
  if(isFirebaseReady()){
    try{
      const cred = await auth.signInWithEmailAndPassword(email, pass);
      localStorage.setItem(SESSION_KEY, JSON.stringify({mode:"user"}));
      applyAuthedUI(cred.user);
      document.getElementById("loginSection").style.display="none";
      document.getElementById("signInModal").style.display="none";
      document.getElementById("createModal").style.display="none";
      showWelcome();
      return;
    }catch(e){
      const msg = (e?.code==="auth/user-not-found")
        ? (currentLang==="ar"?"البريد غير مسجل":currentLang==="fr"?"Email non enregistré":"Email not registered")
        : (e?.code==="auth/wrong-password" || e?.code==="auth/invalid-credential")
          ? (currentLang==="ar"?"كلمة المرور غير صحيحة":currentLang==="fr"?"Mot de passe incorrect":"Wrong password")
          : (currentLang==="ar"?"تعذر تسجيل الدخول":currentLang==="fr"?"Connexion impossible":"Sign in failed");
      alert(msg);
      return;
    }
  }

  // Local fallback
  const accounts=getAccounts();
  const acc=accounts.find(a=>a.email.toLowerCase()===email);
  if(!acc){
    const msg=currentLang==="ar"?"البريد غير مسجل":currentLang==="fr"?"Email non enregistré":"Email not registered";
    alert(msg);
    return;
  }
  if(acc.password!==pass){
    const msg=currentLang==="ar"?"كلمة المرور غير صحيحة":currentLang==="fr"?"Mot de passe incorrect":"Wrong password";
    alert(msg);
    return;
  }
  userProfile.username=acc.name;
  userProfile.avatar=userProfile.avatar||"gust.png";
  document.getElementById("username").innerText=acc.name;
  document.getElementById("userAvatar").src=userProfile.avatar||"gust.png";
  localStorage.setItem("arStoreProfile",JSON.stringify(userProfile));
  localStorage.setItem(SESSION_KEY, JSON.stringify({mode:"user", email}));
  document.getElementById("loginSection").style.display="none";
  document.getElementById("signInModal").style.display="none";
  document.getElementById("createModal").style.display="none";
  showWelcome();
}

