function renderProductReviews(){
  const wrap=document.getElementById("productReviews");
  if(!wrap || !currentProduct) return;

  // Default (local mock) while Firebase loads / not configured
  const fallback = PRODUCT_REVIEWS[currentProduct.name] || {rating:4.7, count: 42, comments:[
    {user:"User", time:"1w", text:"Excellent quality and premium feel."},
    {user:"User", time:"2w", text:"Fast service. Looks luxurious."},
    {user:"User", time:"1m", text:"Highly recommended."}
  ]};

  const state = {rating:fallback.rating, count:fallback.count, comments:fallback.comments};
  const fullStars = Math.floor(state.rating);
  const half = (state.rating - fullStars) >= 0.5;
  const stars = Array.from({length:5}).map((_,i)=>{
    const on = i < fullStars;
    const halfStar = !on && half && i === fullStars;
    return `<span class="star" aria-hidden="true">${on ? "★" : (halfStar ? "★" : "☆")}</span>`;
  }).join("");

  // Share buttons (consistent with existing button styles)
  const shareTitle = currentLang==="ar"?"مشاركة":currentLang==="fr"?"Partager":"Share";
  const shareWhats = currentLang==="ar"?"واتساب":currentLang==="fr"?"WhatsApp":"WhatsApp";
  const shareFb = "Facebook";
  const shareIg = "Instagram";

  wrap.innerHTML = `
    <div class="rating-row">
      <div class="stars" aria-label="${state.rating} out of 5">${stars}</div>
      <div class="rating-meta">${state.rating} (${state.count})</div>
    </div>
    <div class="comment-list">
      ${state.comments.slice(0,3).map(c=>`
        <div class="comment">
          <div class="comment-head">
            <div class="comment-user">${c.user}</div>
            <div class="comment-time">${c.time}</div>
          </div>
          <div class="comment-text">${c.text}</div>
        </div>
      `).join("")}
    </div>
    <div style="margin-top:12px;display:flex;flex-wrap:wrap;gap:10px;justify-content:center;">
      <button class="detail-btn secondary-link" type="button" onclick="playClick();shareCurrentProduct('whatsapp')">${shareTitle} • ${shareWhats}</button>
      <button class="detail-btn secondary-link" type="button" onclick="playClick();shareCurrentProduct('facebook')">${shareTitle} • ${shareFb}</button>
      <button class="detail-btn secondary-link" type="button" onclick="playClick();shareCurrentProduct('instagram')">${shareTitle} • ${shareIg}</button>
    </div>
    <div style="margin-top:12px;">
      <div style="font-size:13px;font-weight:700;color:#1a1a1a;margin-bottom:8px;">
        ${currentLang==="ar"?"أضف مراجعة":currentLang==="fr"?"Ajouter un avis":"Add a review"}
      </div>
      <input type="number" id="reviewRating" min="1" max="5" value="5" style="width:100%;margin:0 0 10px 0;">
      <input type="text" id="reviewText" placeholder="${currentLang==="ar"?"اكتب تعليقك":currentLang==="fr"?"Écrivez votre commentaire":"Write your comment"}" style="width:100%;margin:0 0 10px 0;">
      <button class="detail-btn buy" type="button" onclick="playClick();submitReview()">${currentLang==="ar"?"إرسال":currentLang==="fr"?"Envoyer":"Submit"}</button>
    </div>
  `;

  // If Firebase is configured, hydrate reviews from Firestore (keeps same container/styles)
  if(isFirebaseReady()){
    loadFirestoreReviews().catch(()=>{});
  }
}

async function loadFirestoreReviews(){
  if(!isFirebaseReady() || !currentProduct) return;
  const pid = productIdFrom(currentProduct);
  const snap = await db.collection("products").doc(pid).collection("reviews")
    .orderBy("createdAt","desc")
    .limit(3)
    .get();
  const comments = snap.docs.map(d=>{
    const data = d.data()||{};
    return {
      user: data.username || "User",
      time: data.timeLabel || "",
      text: data.text || ""
    };
  }).filter(c=>c.text);

  // Keep stars/meta as-is; just update list if we have data
  if(comments.length){
    const list = document.querySelector("#productReviews .comment-list");
    if(list){
      list.innerHTML = comments.map(c=>`
        <div class="comment">
          <div class="comment-head">
            <div class="comment-user">${c.user}</div>
            <div class="comment-time">${c.time}</div>
          </div>
          <div class="comment-text">${c.text}</div>
        </div>
      `).join("");
    }
  }
}

async function submitReview(){
  if(!currentProduct) return;
  const text = String(document.getElementById("reviewText")?.value||"").trim();
  const rating = Math.max(1, Math.min(5, parseInt(document.getElementById("reviewRating")?.value)||5));
  if(!text){
    showToast(currentLang==="ar"?"يرجى كتابة تعليق":currentLang==="fr"?"Veuillez écrire un commentaire":"Please write a comment");
    return;
  }
  const ok = await ensureSignedInOrToast();
  if(!ok) return;

  if(isFirebaseReady()){
    const u = auth.currentUser;
    const pid = productIdFrom(currentProduct);
    const username = userProfile.username || u?.displayName || (u?.email||"User").split("@")[0];
    await db.collection("products").doc(pid).set({
      name: currentProduct.name,
      img: currentProduct.img,
      price: currentProduct.price,
      updatedAt: firebase.firestore.FieldValue.serverTimestamp()
    }, {merge:true});
    await db.collection("products").doc(pid).collection("reviews").add({
      uid: u.uid,
      username,
      rating,
      text,
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      timeLabel: "now"
    });
    document.getElementById("reviewText").value="";
    showToast(currentLang==="ar"?"تم إرسال المراجعة":currentLang==="fr"?"Avis envoyé":"Review submitted");
    await loadFirestoreReviews();
    return;
  }

  // Local fallback: append to mock
  const name = currentProduct.name;
  PRODUCT_REVIEWS[name] = PRODUCT_REVIEWS[name] || {rating:4.7, count:0, comments:[]};
  PRODUCT_REVIEWS[name].comments.unshift({user:userProfile.username||"User", time:"now", text});
  PRODUCT_REVIEWS[name].count = (PRODUCT_REVIEWS[name].count||0) + 1;
  document.getElementById("reviewText").value="";
  renderProductReviews();
}

