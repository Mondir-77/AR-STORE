function onTopbarSearchInput(e){
  const val=String(e?.target?.value||"");
  const wrap=document.getElementById("topbarSearchWrap");
  if(wrap) wrap.classList.toggle("has-value", val.trim().length>0);
  if(document.getElementById("productsPage").style.display==="flex"){
    openProducts(lastCategoryId);
  }
}
function clearTopbarSearch(){
  const input=document.getElementById("topbarSearch");
  if(input) input.value="";
  const wrap=document.getElementById("topbarSearchWrap");
  if(wrap) wrap.classList.remove("has-value");
  if(document.getElementById("productsPage").style.display==="flex"){
    openProducts(lastCategoryId);
  }
}

