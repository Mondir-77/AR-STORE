        <div class="purchase-price">${p.price} MAD</div>
        <div class="purchase-quantity">${currentLang==="ar"?"الكمية":currentLang==="fr"?"Quantité":"Quantity"}: 
          <input type="number" min="1" value="${qty}" style="width:90px;padding:8px 10px;border-radius:10px;border:1px solid #ddd;font-size:14px;" onchange="updateCartQty(${idx}, this.value)">
        </div>
        <div class="purchase-total">${t} MAD</div>
      </div>
      <button class="purchase-delete" onclick="playClick();deletePurchase(${idx})">${delTxt}</button>
    </div>`;
  }).join("");
}

function deletePurchase(idx){
  cartItems.splice(idx,1);
  localStorage.setItem("arStorePurchases",JSON.stringify(cartItems));
  updatePurchasesBadge(true);
  renderPurchases();
}

function updateCartQty(idx, value){
  const qty = Math.max(1, parseInt(value)||1);
  if(!cartItems[idx]) return;
  cartItems[idx].quantity = qty;
  cartItems[idx].total = (cartItems[idx].price||0) * qty;
  localStorage.setItem("arStorePurchases",JSON.stringify(cartItems));
  updatePurchasesBadge(true);
  renderPurchases();
}

function buyAllWhatsApp(){
  if(cartItems.length===0)return;
  let total=0;
  let msg=`*Order from AR Store - All Items*%0A%0A`;
  cartItems.forEach(p=>{
    const t=(p.price*(p.quantity||1));
    total+=t;
    msg+=`- ${p.name}: ${p.price} MAD x ${p.quantity||1} = ${t} MAD%0A`;
  });
  msg+=`%0A*Total: ${total} MAD*`;
  window.open(`https://wa.me/${WHATSAPP_NUMBER}?text=${msg}`,"_blank");
}

function buyAllGmail(){
  if(cartItems.length===0)return;
  let total=0;
  let body=`AR Store - Order (Multiple Items)\n\n`;
  cartItems.forEach(p=>{
    const t=(p.price*(p.quantity||1));
    total+=t;
    body+=`- ${p.name}: ${p.price} MAD x ${p.quantity||1} = ${t} MAD\n`;
  });
  body+=`\nTotal: ${total} MAD`;
  window.location.href=`mailto:${STORE_EMAIL}?subject=${encodeURIComponent("AR Store - Full Order")}&body=${encodeURIComponent(body)}`;
}

function backToProducts(){
  hideAllPages();
