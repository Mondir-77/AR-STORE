}

function googleLogin(){
  if(isFirebaseReady()){
    const provider = new firebase.auth.GoogleAuthProvider();
    auth.signInWithPopup(provider).then((cred)=>{
      localStorage.setItem(SESSION_KEY, JSON.stringify({mode:"user"}));
      applyAuthedUI(cred.user);
      document.getElementById("loginSection").style.display="none";
      document.getElementById("signInModal").style.display="none";
      document.getElementById("createModal").style.display="none";
      showWelcome();
    }).catch(()=>{
      alert(currentLang==="ar"?"تعذر تسجيل الدخول عبر Google":currentLang==="fr"?"Connexion Google impossible":"Google login failed");
    });
    return;
  }
  window.location.href="https://accounts.google.com/";
}

function applyAuthedUI(user){
  const displayName = user?.displayName || userProfile.username || (user?.email||"Guest").split("@")[0] || "Guest";
  userProfile.username = displayName;
  document.getElementById("username").innerText = displayName;
  if(user?.photoURL){
    userProfile.avatar = user.photoURL;
  }
  document.getElementById("userAvatar").src = userProfile.avatar || "gust.png";
  localStorage.setItem("arStoreProfile", JSON.stringify(userProfile));

  if(isFirebaseReady() && user?.uid){
    db.collection("profiles").doc(user.uid).get().then((d)=>{
      if(!d.exists) return;
      const p = d.data()||{};
      if(p.username){ userProfile.username=p.username; document.getElementById("username").innerText=p.username; }
      if(p.avatar){ userProfile.avatar=p.avatar; document.getElementById("userAvatar").src=p.avatar; }
      if(p.desc){ userProfile.desc=p.desc; }
      localStorage.setItem("arStoreProfile", JSON.stringify(userProfile));
    }).catch(()=>{});
  }
}

function shareCurrentProduct(platform){
  if(!currentProduct) return;
  const text = `AR STORE - ${currentProduct.name} (${currentProduct.price} MAD)`;
  const url = window.location.href.split("#")[0];
  const shareUrl = `${url}#product=${encodeURIComponent(productIdFrom(currentProduct))}`;
  if(platform==="whatsapp"){
    window.open(`https://wa.me/?text=${encodeURIComponent(text + "\n" + shareUrl)}`,"_blank");
    return;
  }
  if(platform==="facebook"){
    window.open(`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`,"_blank");
    return;
  }
  if(platform==="instagram"){
    // Instagram doesn't support direct web share URLs; copy link as best UX without changing layout.
    try{ navigator.clipboard.writeText(shareUrl); }catch(e){}
    showToast(currentLang==="ar"?"تم نسخ رابط المشاركة":currentLang==="fr"?"Lien copié":"Share link copied");
    return;
  }
}

