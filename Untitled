<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AR STORE</title>
<style>
/* ========== BASE & RESET ========== */
*{margin:0;padding:0;box-sizing:border-box;}
body{
  height:100vh;
  overflow-x:hidden;
  color:rgb(255, 255, 255);
  font-family:ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Arial, sans-serif;
  transition:0.4s;
}

:root{
  --lux-black:#08090b;
  --lux-ink:#0e0f13;
  --lux-glass:rgb(21, 2, 2);
  --lux-glass-2:rgba(255,255,255,0.16);
  --lux-border:rgba(255,255,255,0.18);
  --lux-border-2:rgba(255,255,255,0.10);
  --lux-shadow:0 18px 55px rgba(0,0,0,0.55);
  --lux-shadow-soft:0 10px 35px rgba(0,0,0,0.35);
  --lux-radius:18px;
}

/* Luxury feel without changing layout */
.btn, .modal-btn, .modal-back, .back-btn, .detail-btn, .account-save-btn, .purchase-delete, .help-email, .help-whatsapp, .help-instagram{
  border-radius:16px;
}
.btn, .modal-btn, .back-btn, .detail-btn, .account-save-btn{
  letter-spacing:0.02em;
}

/* Glass treatment */
.topbar,
.modal,
.modal-content,
.card,
.product-card,
.product-slider,
.product-detail-info,
.purchase-card,
.account-card,
.help-card,
#orderNotification{
  -webkit-backdrop-filter: blur(14px);
  backdrop-filter: blur(14px);
}

/* ========== WELCOME PAGE (shown after login) ========== */
#welcomeSection{
  display:none;
  position:fixed;
  inset:0;
  background:linear-gradient(135deg,#000 0%,#1a1a2e 100%);
  flex-direction:column;
  justify-content:center;
  align-items:center;
  z-index:1000;
  opacity:0;
  animation:welcomeFadeIn 1.2s ease forwards;
}
@keyframes welcomeFadeIn{
  from{opacity:0;}
  to{opacity:1;}
}
#welcomeSection.fadeOut{
  animation:welcomeFadeOut 0.8s ease forwards;
}
@keyframes welcomeFadeOut{
  from{opacity:1;}
  to{opacity:0;}
}
.welcome-title{
  font-size:clamp(1.8rem,4vw,2.5rem);
  font-weight:900;
  letter-spacing:0.1em;
  margin-bottom:35px;
  opacity:0;
  animation:slideUp 0.8s ease 0.3s forwards;
}
.welcome-brand{
  font-size:clamp(2.2rem,5vw,3.5rem);
  font-weight:700;
  letter-spacing:0.15em;
  opacity:0;
  animation:slideUp 0.8s ease 0.5s forwards;
}
@keyframes slideUp{
  from{opacity:0;transform:translateY(20px);}
  to{opacity:1;transform:translateY(0);}
}

/* ========== LOGIN SECTION ========== */
#loginSection{
  background:url("Mondir.jpg") no-repeat center center/cover;
  height:100vh;
  display:flex;
  flex-direction:column;
  justify-content:flex-end;
  align-items:center;
  padding-bottom:160px;
  gap:30px;
}

.btn{
  padding:14px 98px;
  min-width:300px;
  text-align:center;
  border:2px solid rgb(244, 243, 243);
  background:linear-gradient(180deg, rgba(255, 255, 255, 0.178),  rgba(6, 0, 25, 0.365));
  color:white;
  font-weight:780;
  font-size:25px;
  cursor:pointer;
  transition:all 0.3s ease;
  border-radius:15px;
  box-shadow:0 10px 30px rgba(0, 0, 0, 0.037);
  text-shadow:0 2px 10px rgba(0,0,0,0.35);
}
.btn:hover{
  background:linear-gradient(180deg, rgba(0, 0, 0, 0.235), rgba(0, 0, 0, 0.203));
  transform:translateY(-2px);
  box-shadow:0 16px 40px rgba(255, 248, 248, 0.45);
}
.lang-box{display:flex;gap:15px;flex-wrap:wrap;justify-content:center;}

/* ========== MODAL (Sign In / Create Account) ========== */
.modal{
  position:fixed;
  inset:0;
  background:radial-gradient(1200px 900px at 50% -10%, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.336));
  display:none;
  justify-content:center;
  align-items:center;
  z-index:100;
  backdrop-filter:blur(10px);
}

.modal-content{
  background:linear-gradient(180deg, rgba(34, 8, 185, 0.712), rgba(255, 252, 252, 0.68));
  color:#000000;
  padding:35px;
  width:min(380px,92vw);
  border-radius:20px;
  text-align:center;
  box-shadow:var(--lux-shadow);
  animation:modalSlide 0.3s ease;
  border:1px solid rgb(0, 0, 0);
}
@keyframes modalSlide{
  from{opacity:0;transform:translateY(-20px);}
  to{opacity:1;transform:translateY(0);}
}

.modal-content h2{
  margin-bottom:25px;
  font-size:1.5rem;
  font-weight:800;
}

.modal-content input{
  width:100%;
  padding:14px 16px;
  margin:10px 0;
  border:1px solid rgba(0,0,0,0.10);
  border-radius:10px;
  font-size:16px;
  transition:border 0.2s;
  background:rgb(255, 255, 255);
}
.modal-content input:focus{
  outline:none;
  border-color:rgba(0,122,255,0.65);
}

/* Password field with eye icon */
.password-wrapper{
  position:relative;
  width:100%;
}
.password-wrapper input{
  padding-right:50px;
}
.password-toggle{
  position:absolute;
  right:14px;
  top:50%;
  transform:translateY(-50%);
  background:none;
  border:none;
  cursor:pointer;
  padding:5px;
  color:#666;
  font-size:18px;
  transition:color 0.2s;
}
.password-toggle:hover{color:#000;}

.modal-btn{
  display:block;
  width:100%;
  padding:14px;
  margin-top:12px;
  background:linear-gradient(180deg, rgba(12,12,14,0.92), rgba(0,0,0,0.92));
  color:white;
  cursor:pointer;
  border-radius:10px;
  border:none;
  font-size:18px;
  font-weight:500;
  transition:all 0.3s;
  box-shadow:0 10px 24px rgba(0,0,0,0.25);
}
.modal-btn:hover{background:linear-gradient(180deg, rgba(20,20,22,0.95), rgba(2,2,2,0.95));transform:translateY(-1px);}
.modal-btn.secondary{
  background:linear-gradient(180deg, rgba(255,255,255,0.20), rgba(255,255,255,0.10));
  color:#ffffff;
  border:1px solid rgba(255,255,255,0.22);
}
.modal-btn.secondary:hover{background:linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.14));}


/* Back button in modals - fancy blue */
.modal-back{
  margin-top:20px;
  padding:12px 24px;
  background:linear-gradient(135deg,#007aff,#0051d5);
  color:rgb(255, 250, 250);
  border:none;
  cursor:pointer;
  border-radius:10px;
  font-size:15px;
  font-weight:600;
  transition:all 0.35s ease;
  box-shadow:0 4px 15px rgba(0,122,255,0.4);
}
.modal-back:hover{
  background:linear-gradient(135deg,#0066d6,#0047b8);
  transform:translateY(-2px);
  box-shadow:0 6px 20px rgba(0,122,255,0.5);
}
.modal-back:active{transform:translateY(0);}

/* ========== FOOTER (global) ========== */
footer{
    position:fixed;
  bottom:0;
  left:0;
  right:0;
  padding:20px 25px;
  font-size:20px;
  font-weight:700;
  color:rgb(255, 255, 255);
  text-align:center;
}
/* ========== STORE SECTION ========== */
#storeSection{
  display:none;
  flex-direction:column;
  min-height:100vh;
  padding-bottom:70px;
  background:url("AR.jpg") no-repeat center center/cover;
}

.topbar{
  display:grid;
  grid-template-columns:1fr minmax(220px, 520px) 1fr;
  align-items:center;
  padding:18px 25px;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.10), rgba(255,255,255,0.02)),
    radial-gradient(900px 120px at 50% 0%, rgba(255,255,255,0.18), rgba(255,255,255,0.00)),
    rgba(0,0,0,0.58);
  border-bottom:1px solid rgba(255,255,255,0.12);
  box-shadow:0 16px 45px rgba(0,0,0,0.45);
  position:sticky;
  top:0;
  z-index:50;
}
.topbar::before{
  content:"";
  position:absolute;
  inset:0;
  pointer-events:none;
  background:linear-gradient(120deg, rgba(255,255,255,0.14), rgba(255,255,255,0) 35%, rgba(255,255,255,0.08) 65%, rgba(255,255,255,0));
  opacity:0.55;
  mix-blend-mode:screen;
}

.menu{
  display:flex;
  gap:20px;
  font-weight:800;
  font-size:16px;
  flex-wrap:wrap;
}
.menu span{
  cursor:pointer;
  transition:all 0.3s;
}
.menu span:hover{color:#007aff;}
.menu-item-wrap{
  position:relative;
  display:inline-block;
}
.purchases-badge{
  position:absolute;
  top:-6px;
  right:-10px;
  min-width:18px;
  height:18px;
  padding:0 5px;
  background:#dc3545;
  color:white;
  font-size:11px;
  font-weight:700;
  border-radius:50%;
  display:flex;
  align-items:center;
  justify-content:center;
  display:none;
}
.purchases-badge.show{display:flex;}

.user-box{
  display:flex;
  align-items:center;
  gap:12px;
  font-size:16px;
  font-weight:750;
  justify-content:flex-end;
}

.user-box img{
  width:48px;
  height:48px;
  border-radius:50%;
  border:2px solid rgb(255, 255, 255);
  object-fit:cover;
  box-shadow:0 10px 22px rgba(0,0,0,0.35);
}

/* Center search (topbar) */
.topbar-search{
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
  z-index:1;
}
.topbar-search input{
  width:100%;
  max-width:520px;
  height:44px;
  padding:0 44px 0 44px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,0.16);
  background:linear-gradient(180deg, rgba(255,255,255,0.14), rgba(255,255,255,0.08));
  color:#fff;
  outline:none;
  box-shadow:0 14px 38px rgba(0,0,0,0.35);
}
.topbar-search input::placeholder{color:rgba(255,255,255,0.70);}
.topbar-search input:focus{
  border-color:rgba(255,255,255,0.28);
  background:linear-gradient(180deg, rgba(255,255,255,0.18), rgba(255,255,255,0.10));
}
.topbar-search .search-icon{
  position:absolute;
  left:14px;
  width:18px;
  height:18px;
  opacity:0.82;
  z-index:2;
  pointer-events:none;
}
.topbar-search .search-clear{
  position:absolute;
  right:10px;
  width:30px;
  height:30px;
  border-radius:999px;
  border:1px solid rgba(255,255,255,0.16);
  background:rgba(255,255,255,0.10);
  color:rgba(255,255,255,0.92);
  cursor:pointer;
  display:none;
  align-items:center;
  justify-content:center;
  transition:transform 0.2s ease, background 0.2s ease;
}
.topbar-search .search-clear:hover{transform:scale(1.05);background:rgba(255,255,255,0.16);}
.topbar-search.has-value .search-clear{display:flex;}

/* ========== CATALOGUE - 5 categories in row, Artworks 5 items ========== */
.categories{
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  gap:10px;
  padding:50px 25px 100px;
}

.categories-row{
  display:flex;
  justify-content:center;
  align-items:center;
  gap:25px;
  flex-wrap:wrap;
  width:100%;
  max-width:1100px;
}

.card{
    width:clamp(150px,180px,210px);
  height:280px;
  background:linear-gradient(180deg, rgba(255,255,255,0.12), rgba(255,255,255,0.06));
  border-radius:30px;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  transition:all 0.4s ease;
  backdrop-filter:blur(10px);
  border:1px solid rgba(255, 255, 255, 0.22);
  box-shadow:0 18px 45px rgba(0,0,0,0.28);

}
.card img{
  width:85%;
  height:165px;
  object-fit:cover;
  border-radius:12px;
}
.card span{
  margin-top:10px;
  font-weight:730;
  font-size:25px;
  text-align:center;
}
.card:hover{
  transform:scale(1.06);
  box-shadow:0 12px 35px rgba(0,0,0,0.25);
  background:linear-gradient(180deg, rgba(255,255,255,0.18), rgba(9, 11, 148, 0.28));
  border-color:rgba(255,255,255,0.4);
}
.artworks-row{
  display:flex;
  justify-content:center;
  gap:20px;
  flex-wrap:wrap;
  width:100%;
  max-width:900px;
}
.artworks-row .card{
  flex:0 0 auto;
  min-width:130px;
  max-width:160px;
}
.artworks-label{
  font-size:22px;
  font-weight:700;
  color:white;
  text-shadow:0 2px 8px rgba(0,0,0,0.5);
  margin-top:15px;
}

/* ========== PRODUCTS / CATALOGUE PAGE ========== */
#productsPage{
  display:none;
  flex-direction:column;
  min-height:100vh;
  padding:100px 20px 90px;
  background:url("AR.jpg") no-repeat center center/cover;
  align-items:center;
  overflow-y:auto;
  position:relative;
}

.products-grid{
  display:grid;
  grid-template-columns:1fr 1.5fr 1fr;
  gap:25px;
  width:min(90%,1100px);
  align-items:center;
  margin:auto;
}

@media(max-width:768px){
  .products-grid{grid-template-columns:1fr;gap:20px;}
}

.product-card{
  background:linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.78));
  border-radius:20px;
  overflow:hidden;
  box-shadow:var(--lux-shadow-soft);
  transition:all 0.4s ease;
  cursor:pointer;
  color:#1a1a1a;
  border:1px solid rgba(255,255,255,0.6);
}
.product-card img{
  width:100%;
  display:block;
  object-fit:cover;
}
.product-card.small img{height:200px;}
.product-card.big img{height:300px;}
.product-card .product-info{
  padding:18px;
  text-align:center;
}
.product-card .product-name{
  font-size:16px;
  font-weight:600;
  margin-bottom:8px;
}
.product-card .product-price{
  font-size:18px;
  font-weight:700;
  color:#007aff;
}
.product-card:hover{
  transform:scale(1.05);
  box-shadow:0 20px 50px rgba(0,0,0,0.3);
}

.big .product-info{padding:22px;}
.big .product-name{font-size:18px;}
.big .product-price{font-size:22px;}

.back-btn{
  position:absolute;
  top:25px;
  left:25px;
  padding:12px 22px;
  background:linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.78));
  color:#1a1a1a;
  font-weight:600;
  cursor:pointer;
  border-radius:12px;
  border:none;
  font-size:15px;
  box-shadow:0 4px 15px rgba(0,0,0,0.2);
  transition:all 0.3s;
  z-index:10;
  border:1px solid rgba(255,255,255,0.65);
}
.back-btn:hover{
  background:#f0f0f0;
  transform:translateY(-2px);
}

/* ========== PRODUCT DETAIL PAGE ========== */
#productDetailPage{
  display:none;
  flex-direction:column;
  min-height:100vh;
  padding:80px 20px 90px;
  background:linear-gradient(180deg,#1a1a2e 0%,#16213e 100%);
  overflow-y:auto;
  position:relative;
}

.product-detail-container{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:50px;
  max-width:1000px;
  margin:0 auto;
  align-items:start;
}

@media(max-width:768px){
  .product-detail-container{grid-template-columns:1fr;}
}

/* Image slider */
.product-slider{
  position:relative;
  background:linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.78));
  border-radius:24px;
  overflow:hidden;
  box-shadow:0 20px 60px rgba(0,0,0,0.4);
  border:1px solid rgba(255,255,255,0.65);
}
.slider-main{
  width:100%;
  aspect-ratio:1;
  position:relative;
  overflow:hidden;
  background:rgba(255,255,255,0.75);
}
/* Smooth slide (3 images per product) */
.slider-track{
  display:flex;
  width:300%;
  height:100%;
  transition:transform 0.55s cubic-bezier(.2,.85,.25,1);
}
.slider-track img{
  width:100%;
  height:100%;
  object-fit:cover;
  flex:0 0 33.3333%;
}

.slider-arrow{
  position:absolute;
  top:50%;
  transform:translateY(-50%);
  width:50px;
  height:50px;
  background:linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.75));
  border:none;
  border-radius:50%;
  cursor:pointer;
  font-size:24px;
  color:#1a1a1a;
  transition:all 0.3s;
  z-index:5;
  display:flex;
  align-items:center;
  justify-content:center;
  box-shadow:0 12px 28px rgba(0,0,0,0.25);
  border:1px solid rgba(255,255,255,0.65);
}
.slider-arrow:hover{background:white;transform:translateY(-50%) scale(1.1);}
.slider-arrow.prev{left:15px;}
.slider-arrow.next{right:15px;}

/* Product detail right side */
.product-detail-info{
  background:linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.78));
  border-radius:24px;
  padding:35px;
  color:#1a1a1a;
  box-shadow:0 20px 60px rgba(0,0,0,0.3);
  border:1px solid rgba(255,255,255,0.65);
}
.product-detail-info h1{
  font-size:28px;
  margin-bottom:15px;
  font-weight:700;
}
.product-detail-price{
  font-size:26px;
  font-weight:700;
  color:#007aff;
  margin-bottom:25px;
}
.product-detail-info input{
  width:100%;
  padding:14px 16px;
  margin:10px 0;
  border:1px solid #ddd;
  border-radius:10px;
  font-size:16px;
}
.product-detail-info input:focus{
  outline:none;
  border-color:#007aff;
}
.detail-btn{
  display:block;
  width:100%;
  padding:16px;
  margin-top:12px;
  border:none;
  border-radius:12px;
  font-size:17px;
  font-weight:600;
  cursor:pointer;
  transition:all 0.3s;
  text-align:center;
}
.detail-btn.whatsapp{
  background:#25D366;
  color:white;
}
.detail-btn.whatsapp:hover{background:#20bd5a;transform:translateY(-2px);}
.detail-btn.buy{
  background:linear-gradient(135deg, #0b2b57, #007aff);
  color:white;
}
.detail-btn.buy:hover{background:#0066d6;transform:translateY(-2px);}

/* Reviews (product detail) */
.product-reviews{
  margin-top:18px;
  padding-top:16px;
  border-top:1px solid rgba(0,0,0,0.10);
}
.rating-row{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
}
.stars{
  display:flex;
  gap:4px;
  font-size:16px;
  color:#c9a227;
  letter-spacing:0.02em;
}
.stars .star{
  filter:drop-shadow(0 2px 6px rgba(0,0,0,0.18));
}
.rating-meta{
  font-size:13px;
  color:#666;
  font-weight:600;
}
.comment-list{
  margin-top:12px;
  display:flex;
  flex-direction:column;
  gap:10px;
}
.comment{
  background:rgba(0,0,0,0.04);
  border:1px solid rgba(0,0,0,0.06);
  border-radius:14px;
  padding:12px 14px;
}
.comment .comment-head{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  margin-bottom:6px;
}
.comment .comment-user{
  font-weight:700;
  color:#1a1a1a;
  font-size:13px;
}
.comment .comment-time{
  font-size:12px;
  color:#777;
  font-weight:600;
}
.comment .comment-text{
  font-size:13px;
  color:#333;
  line-height:1.35;
}
.detail-btn.back{
  background:#f0f0f0;
  color:#1a1a1a;
  margin-top:20px;
}
.detail-btn.back:hover{background:#e0e0e0;}
.detail-btn.secondary-link{
  background:#e8e8e8;
  color:#333;
  margin-top:10px;
}
.detail-btn.secondary-link:hover{background:#ddd;}
.product-detail-desc{
  margin-bottom:20px;
  color:#555;
  font-size:15px;
  line-height:1.5;
  min-height:24px;
}

/* ========== MY PURCHASES PAGE ========== */
#purchasesPage{
  display:none;
  flex-direction:column;
  min-height:100vh;
  padding:100px 20px 90px;
  background:linear-gradient(180deg,#1a1a2e 0%,#16213e 100%);
  overflow-y:auto;
  position:relative;
}

.purchases-container{
  max-width:700px;
  margin:0 auto;
  width:100%;
}
.purchase-card{
  background:white;
  border-radius:20px;
  padding:25px;
  margin-bottom:25px;
  display:flex;
  gap:25px;
  align-items:center;
  box-shadow:0 10px 40px rgba(0,0,0,0.2);
  color:#1a1a1a;
}
.purchase-card img{
  width:100px;
  height:100px;
  object-fit:cover;
  border-radius:12px;
}
.purchase-details{flex:1;}
