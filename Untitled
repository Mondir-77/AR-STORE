      return;
    }
  }

  // Local fallback (no Firebase config yet)
  const accounts=getAccounts();
  if(accounts.some(a=>a.email.toLowerCase()===email)){
    const msg=currentLang==="ar"?"البريد مستخدم مسبقاً":currentLang==="fr"?"Cet email est déjà utilisé":"This email is already registered";
    alert(msg);
    return;
  }
  accounts.push({name,email,password:pass});
  setAccounts(accounts);
