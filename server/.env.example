PORT=3000
DATABASE_URL="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/arstore?retryWrites=true&w=majority"
JWT_SECRET="change-this-to-a-long-random-string-in-production"
ADMIN_EMAIL="admin@arstore.local"
ADMIN_PASSWORD="change-me-strong-password"
OPENAI_API_KEY=""

# Persistent media (required on Render — local /uploads is wiped on restart)
# Get from https://cloudinary.com/console → API Keys
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# Or use separate vars:
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Force full seed on next deploy (optional, one-time)
# RUN_DB_SEED=true
